PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/carbonflow

# Base URLs (emails / invite links)
APP_URL=http://localhost:5000
# Vite dev server — used for supplier network signup links; falls back to APP_URL
FRONTEND_URL=http://localhost:5173
# Comma-separated list optional: handled via APP_URL/FRONTEND_URL defaults in server.js
# CORS_ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app,https://www.yourdomain.com

# Optional default ₹/t CO₂e when company_region_settings row missing (override is per-company)
# DEFAULT_CARBON_PRICE_INR=2500

# Firebase Admin (choose one approach)
FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional SMTP config (if not set, invite/reminder emails are skipped)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
